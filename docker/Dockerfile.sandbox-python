# ZenithLoom — Python Sandbox for Tool Discovery
# Build: docker build -t bb-sandbox-python -f docker/Dockerfile.sandbox-python .
# Usage: docker run --rm --memory=1g --cpus=1 --read-only --tmpfs /workspace:rw bb-sandbox-python

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Pre-install common test runners
RUN pip install --no-cache-dir pytest pytest-timeout

# Non-root user for safety
RUN useradd -m sandbox
USER sandbox

WORKDIR /workspace

CMD ["/bin/bash"]
