FROM qwen3-coder-next:q4_K_M

# RTX 5090 32GB — 模型总共 48 层, 权重 55.5GB
# 放 22 层到 GPU (~25GB), 留 ~7GB 给 KV cache
# 剩余 26 层 offload 到 128GB RAM
PARAMETER num_gpu 22

# 上下文窗口 — executor tool loop 不需要太大
# 8192 tokens 的 KV cache 约占 2-4GB VRAM
PARAMETER num_ctx 8192

# 保持原模型的采样参数
PARAMETER temperature 1
PARAMETER top_k 40
PARAMETER top_p 0.95
