# BootstrapBuilder 环境变量配置
# 复制此文件为 .env 并填入真实值
# 所有 Agent 行为配置（模型、工具、工作目录等）均在 blueprints/<name>/entity.json 中设置

# ── 必填：Discord Bot ─────────────────────────────────────────────────────────
# 从 Discord Developer Portal 获取（需开启 Message Content Intent）
DISCORD_BOT_TOKEN=

# 授权用户白名单：填入 Discord 数字 ID（逗号分隔）
# 留空 = 任何人均可使用（仅适合私有服务器）
# 用 !whoami 命令获取自己的 ID
DISCORD_ALLOWED_USERS=

# ── 可选：调试 ────────────────────────────────────────────────────────────────
# 设为 1 开启详细日志（prompt 内容、SDK 交互等）
DEBUG=
