# 赛博集团 0号管家 - 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM API Keys
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Discord Bot（从 Discord Developer Portal 获取）
DISCORD_BOT_TOKEN=

# 身份认证白名单：填入授权用户的 Discord 数字 ID（逗号分隔）
# 留空 = 任何人均可使用（仅适合私有服务器）
# 用 !whoami 命令获取自己的 ID
DISCORD_ALLOWED_USERS=

# 会话 ID — 所有接口共用同一个，不要改动
SESSION_THREAD_ID=boss_bootstrap_session_01

# Provider 模式（cli = 使用本地 CLI，api = 使用 API key）
CLAUDE_PROVIDER=cli
GEMINI_PROVIDER=cli

# Claude CLI 行为
CLAUDE_SKIP_PERMISSIONS=true
CLAUDE_TOOLS=Bash,Read,Write,Edit,Glob,Grep

# Gemini CLI 行为
GEMINI_YOLO=false
