{
  "llm": "claude",
  "channel_history_limit": 0,
  "graph": {
    "nodes": [
      {
        "id": "claude_main",
        "type": "CLAUDE_CLI",
        "model": null,
        "tools": [
          "Read",
          "Write",
          "Edit",
          "Bash",
          "Glob",
          "Grep"
        ],
        "permission_mode": "bypassPermissions",
        "setting_sources": null,
        "settings_override": {
          "enabledPlugins": []
        },
        "first_turn_suffix": "Hani:",
        "user_msg_prefix": "老板: ",
        "tombstone_enabled": true,
        "tool_rules": [
          {
            "pattern": "论文|paper|arXiv|arxiv|研究|publication",
            "flags": [
              "IGNORECASE"
            ],
            "tools": [
              "WebFetch",
              "WebSearch"
            ]
          },
          {
            "pattern": "搜索|search|网络|internet|url|http",
            "flags": [
              "IGNORECASE"
            ],
            "tools": [
              "WebFetch",
              "WebSearch"
            ]
          },
          {
            "pattern": "notebook|jupyter|\\.ipynb",
            "flags": [
              "IGNORECASE"
            ],
            "tools": [
              "NotebookEdit"
            ]
          }
        ]
      },
      {
        "id": "validate",
        "type": "VALIDATE"
      },
      {
        "id": "git_snapshot",
        "type": "GIT_SNAPSHOT"
      },
      {
        "id": "git_rollback",
        "type": "GIT_ROLLBACK"
      },
      {
        "id": "debate_brainstorm",
        "type": "SUBGRAPH_REF",
        "agent_dir": "blueprints/functional_graphs/debate_gemini_first",
        "max_retry": 1,
        "state_in": {
          "task": "routing_context",
          "knowledge_vault": "knowledge_vault",
          "project_docs": "project_docs"
        },
        "state_out": {
          "debate_conclusion": "last_message"
        }
      },
      {
        "id": "debate_design",
        "type": "SUBGRAPH_REF",
        "agent_dir": "blueprints/functional_graphs/debate_claude_first",
        "max_retry": 1,
        "state_in": {
          "task": "routing_context",
          "knowledge_vault": "knowledge_vault",
          "project_docs": "project_docs"
        },
        "state_out": {
          "debate_conclusion": "last_message"
        }
      },
      {
        "id": "gmail_reader",
        "type": "EXTERNAL_TOOL",
        "node_config": {
          "command": [
            "bash",
            "-c",
            "gws gmail users messages list --params '{\"userId\":\"me\",\"maxResults\":10,\"labelIds\":\"INBOX\"}' --format json 2>/dev/null | python3 -c \"\nimport json,sys,subprocess\ndata=json.load(sys.stdin)\nmsgs=data.get('messages',[])[:10]\nresult=[]\nfor m in msgs:\n  r=subprocess.run(['gws','gmail','users','messages','get','--params',json.dumps({'userId':'me','id':m['id'],'format':'metadata'}),'--format','json'],capture_output=True,text=True)\n  if r.returncode==0:\n    out='\\n'.join(l for l in r.stdout.splitlines() if 'keyring' not in l.lower())\n    msg=json.loads(out)\n    headers={h['name']:h['value'] for h in msg.get('payload',{}).get('headers',[])}\n    result.append({'id':m['id'],'from':headers.get('From',''),'subject':headers.get('Subject',''),'date':headers.get('Date',''),'snippet':msg.get('snippet','')[:150],'labels':msg.get('labelIds',[])})\nprint(json.dumps(result,ensure_ascii=False,indent=2))\n\""
          ],
          "description": "读取收件箱最近10封邮件（发件人、主题、时间、摘要）",
          "timeout": 60
        }
      },
      {
        "id": "drive_files",
        "type": "EXTERNAL_TOOL",
        "node_config": {
          "command": [
            "gws",
            "drive",
            "files",
            "list"
          ],
          "description": "列出 Google Drive 最近文件",
          "timeout": 30
        }
      },
      {
        "id": "apex_coder",
        "type": "SUBGRAPH_REF",
        "agent_dir": "blueprints/functional_graphs/apex_coder",
        "max_retry": 1,
        "state_in": {
          "routing_context": "routing_context",
          "workspace": "workspace",
          "project_root": "project_root",
          "knowledge_vault": "knowledge_vault",
          "project_docs": "project_docs"
        },
        "state_out": {
          "apex_conclusion": "last_message"
        }
      },
      {
        "id": "tool_discovery",
        "type": "SUBGRAPH_REF",
        "agent_dir": "blueprints/functional_graphs/tool_discovery",
        "max_retry": 1,
        "state_in": {
          "user_query": "routing_context",
          "routing_context": "routing_context",
          "workspace": "workspace",
          "project_root": "project_root",
          "knowledge_vault": "knowledge_vault",
          "project_docs": "project_docs"
        },
        "state_out": {
          "discovery_report": "last_message"
        }
      }
    ],
    "edges": [
      {
        "id": "e_start_2_claude",
        "from": "__start__",
        "to": "claude_main"
      },
      {
        "id": "e_claude_2_snapshot",
        "from": "claude_main",
        "to": "git_snapshot"
      },
      {
        "id": "e_snapshot_2_validate",
        "from": "git_snapshot",
        "to": "validate"
      },
      {
        "id": "e_validate_2_brainstorm",
        "type": "routing_to",
        "from": "validate",
        "to": "debate_brainstorm"
      },
      {
        "id": "e_validate_2_design",
        "type": "routing_to",
        "from": "validate",
        "to": "debate_design"
      },
      {
        "id": "e_validate_2_gmail",
        "type": "routing_to",
        "from": "validate",
        "to": "gmail_reader"
      },
      {
        "id": "e_validate_2_drive",
        "type": "routing_to",
        "from": "validate",
        "to": "drive_files"
      },
      {
        "id": "e_validate_2_end",
        "type": "no_routing",
        "from": "validate",
        "to": "__end__"
      },
      {
        "id": "e_validate_2_rollback",
        "type": "on_error",
        "from": "validate",
        "to": "git_rollback"
      },
      {
        "id": "e_brainstorm_2_claude",
        "from": "debate_brainstorm",
        "to": "claude_main"
      },
      {
        "id": "e_design_2_claude",
        "from": "debate_design",
        "to": "claude_main"
      },
      {
        "id": "e_rollback_2_claude",
        "from": "git_rollback",
        "to": "claude_main"
      },
      {
        "id": "e_validate_2_apex",
        "type": "routing_to",
        "from": "validate",
        "to": "apex_coder"
      },
      {
        "id": "e_gmail_2_claude",
        "from": "gmail_reader",
        "to": "claude_main"
      },
      {
        "id": "e_drive_2_claude",
        "from": "drive_files",
        "to": "claude_main"
      },
      {
        "id": "e_apex_2_claude",
        "from": "apex_coder",
        "to": "claude_main"
      },
      {
        "id": "e_validate_2_discovery",
        "type": "routing_to",
        "from": "validate",
        "to": "tool_discovery"
      },
      {
        "id": "e_discovery_2_claude",
        "from": "tool_discovery",
        "to": "claude_main"
      }
    ]
  },
  "max_retries": 2,
  "persona_files": [
    "ROLE.md",
    "PROTOCOL.md"
  ]
}