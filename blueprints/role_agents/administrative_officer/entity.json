{
  "llm": "llama",
  "channel_history_limit": 0,
  "mcp": [
    {
      "name": "comfyui-video",
      "module": "mcp_servers.comfyui.server",
      "module_args": ["--transport", "sse", "--port", "8103", "--comfyui-host", "localhost", "--comfyui-port", "8188"],
      "url": "http://localhost:8103/sse",
      "shared": true,
      "dependency": {
        "name": "comfyui-backend",
        "check_url": "http://localhost:8188/system_stats",
        "start_cmd": ["/mnt/c/Windows/System32/cmd.exe", "/c",
          "D:\\ComfyUI_windows_portable\\python_embeded\\python.exe",
          "D:\\ComfyUI_windows_portable\\ComfyUI\\main.py",
          "--listen", "0.0.0.0", "--port", "8188"],
        "timeout": 60
      }
    },
    {
      "name": "agent_mail",
      "module": "mcp_servers.agent_mail",
      "module_args": ["--transport", "sse", "--host", "127.0.0.1", "--port", "8200"],
      "url": "http://localhost:8200/sse",
      "shared": true,
      "proxy": "agent_mail"
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "llama_main",
        "type": "OLLAMA",
        "extra_persona": true,
        "persona_files": ["./ROLE.md", "./PROTOCOL.md"],
        "model": "gemma4:e4b",
        "endpoint": "http://localhost:11434",
        "timeout": 300,
        "first_turn_suffix": "Asa:",
        "user_msg_prefix": "",
        "tombstone_enabled": false,
        "tools": ["read_file", "write_file", "bash_exec", "list_dir"],
        "tool_rules": [],
        "options": {
          "think": "medium"
        }
      }
    ],
    "edges": [
      {
        "from": "__start__",
        "to": "llama_main"
      },
      {
        "from": "llama_main",
        "to": "__end__"
      }
    ]
  },
  "max_retries": 2
}