{
  "name": "system_stats_heartbeat",
  "description": "系统资源监控（CPU/内存/磁盘/GPU）",
  "tasks": [
    {
      "id": "stats_system",
      "type": "SYSTEM_STATS",
      "interval_hours": 0.5,
      "thresholds": {
        "mem_percent": 90,
        "swap_percent": 80,
        "disk_percent": 90,
        "gpu_temp": 85,
        "gpu_mem_percent": 95
      }
    }
  ]
}
